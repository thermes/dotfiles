{{- if ne .chezmoi.os "windows" }}
# lesspipe.sh
[".local/bin/lesspipe.sh"]
    type = "file"
    url = "https://raw.githubusercontent.com/wofr06/lesspipe/refs/heads/lesspipe/lesspipe.sh"
    refreshPeriod = "168h"
    executable = true
[".local/bin/lesscomplete"]
    type = "file"
    url = "https://raw.githubusercontent.com/wofr06/lesspipe/refs/heads/lesspipe/lesscomplete"
    refreshPeriod = "168h"
    executable = true
[".local/share/zsh/completions/_less"]
    type = "file"
    url = "https://raw.githubusercontent.com/wofr06/lesspipe/refs/heads/lesspipe/zsh_completion"
    refreshPeriod = "168h"
{{- end }}

{{ if eq .chezmoi.os "linux" }}
{{   if (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}
# wsl2-ssh-agent
[".local/bin/wsl2-ssh-agent"]
    type = "file"
    url = "https://github.com/mame/wsl2-ssh-agent/releases/latest/download/wsl2-ssh-agent"
    refreshPeriod = "168h"
    executable = true
{{   end }}
{{ end }}
